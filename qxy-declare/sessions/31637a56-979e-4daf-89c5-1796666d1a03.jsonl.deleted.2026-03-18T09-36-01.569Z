{"type":"message","id":"3c9f4e8b","parentId":"164649aa","timestamp":"2026-03-18T08:36:19.716Z","message":{"role":"toolResult","toolCallId":"call_4baa193db5624f3db6d79cd0","toolName":"read","content":[{"type":"text","text":"{\n  \"base_url\": \"http://localhost:18800\",\n  \"timeout\": 30,\n  \"retry_max\": 3,\n  \"retry_backoff\": 2,\n\n  \"endpoints\": {\n    \"auth\":                         \"/api-66569900\",\n\n    \"login_send_code\":              \"/api-222535153\",\n    \"login_upload_code\":            \"/api-240989393\",\n    \"get_company_list\":             \"/api-299948557\",\n    \"get_natural_person_companies\": \"/api-145168283\",\n    \"create_company\":               \"/api-145565464\",\n    \"create_account\":               \"/api-149415738\",\n    \"check_quick_login\":            \"/api-164618489\",\n    \"login_tax_bureau\":             \"/api-164576229\",\n\n    \"query_org_info\":               \"/v2/public/org/loadOrgTaxInfo\",\n    \"get_org_info_result\":          \"/v2/public/org/queryOrgInfo\",\n\n    \"initiate_roster_entry\":        \"/api-66960663\",\n    \"query_task_info\":              \"/v2/tax/qys/queryTaskInfo\",\n\n    \"load_init_data_task\":          \"/api-69420373\",\n    \"get_init_data\":                \"/api-69497719\",\n\n    \"simplified_declare\":           \"/v2/tax/qys/loadSimplifiedDeclareTask\",\n    \"query_simplified_result\":      \"/v2/tax/qys/querySimplifiedDeclareTaskInfo\",\n\n    \"upload_tax_report\":            \"/api-67298736\",\n    \"query_tax_report_result\":      \"/api-67919304\",\n\n    \"upload_financial_report\":      \"/api-67585521\",\n    \"query_financial_report_result\":\"/api-67922325\",\n\n    \"load_pdf_task\":                \"/api-67645165\",\n    \"load_wq_pdf_task\":             \"/api-67646997\",\n    \"query_pdf_result\":             \"/api-212658227\",\n\n    \"load_declare_info_task\":       \"/api-66965100\",\n\n    \"initiate_missing_check\":       \"/api-66968884\",\n\n    \"load_payment_task\":            \"/api-67662292\",\n    \"query_payment_result\":         \"/api-67976986\",\n\n    \"load_wszm_task\":               \"/api-67648072\",\n    \"query_wszm_result\":            \"/api-79797899\"\n  },\n\n  \"mcp_servers\": {\n    \"roster_entry\":         \"https://mcp.qixiangyun.com/mcp/roster_entry-http\",\n    \"task_query\":           \"https://mcp.qixiangyun.com/mcp/task_query-http\",\n    \"task_execution\":       \"https://mcp.qixiangyun.com/mcp/task_execution-http\",\n    \"enterprise_management\":\"https://mcp.qixiangyun.com/mcp/enterprise_management-http\",\n    \"financial_report\":     \"https://mcp.qixiangyun.com/mcp/financial_report-http\",\n    \"financial_report_result\":\"https://mcp.qixiangyun.com/mcp/financial_report_result-http\",\n    \"tax_report_upload\":    \"https://mcp.qixiangyun.com/mcp/tax_report_upload-http\",\n    \"tax_report_result\":    \"https://mcp.qixiangyun.com/mcp/tax_report_result-http\",\n    \"initialize_data\":      \"https://mcp.qixiangyun.com/mcp/initialize_data-http\",\n    \"missing_declaration\":  \"https://mcp.qixiangyun.com/mcp/missing_declaration_check-http\",\n    \"tax_payment_certificate\":\"https://mcp.qixiangyun.com/mcp/tax_payment_certificate-http\"\n  },\n\n  \"task_polling\": {\n    \"interval_seconds\": 10,\n    \"max_attempts\": 30,\n    \"status_field\": \"business_status\",\n    \"status_values\": {\n      \"processing\": 1,\n      \"failed\": 2,\n      \"completed\": 3\n    }\n  },\n\n  \"auth\": {\n    \"type\": \"bearer\",\n    \"token_env\": \"QXY_API_TOKEN\",\n    \"token_cache_days\": 15\n  },\n\n  \"state_dir\": \"/Users/kristyzhang/.openclaw/workspace-qxy-declare/states\"\n}\n"}],"isError":false,"timestamp":1773822979711}}
{"type":"message","id":"bca4c615","parentId":"3c9f4e8b","timestamp":"2026-03-18T08:36:19.727Z","message":{"role":"toolResult","toolCallId":"call_6819196eaadc469cba07c30a","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nstate_machine.py — 申报流程状态机引擎（强制交互版）\n\n核心机制：\n  每个需要用户交互的节点，状态机会设置 mandatory_interaction 标记。\n  Agent 必须真正和用户交互后，通过 inject 写入用户的回复，\n  状态机会验证交互记录存在后才允许推进。\n  LLM 不可以代替用户做任何决定。\n\n强制交互节点：\n  1. NOTIFY_TAXES    — 通知用户本月需申报的税种，用户确认后继续\n  2. WAIT_UPLOAD     — 等待用户上传 Excel，必须收到真实文件\n  3. PARSE_FAIL      — 解析失败时通知用户重新上传\n  4. CONFIRM_INCOME  — 询问用户是否有无票收入，必须等用户回复\n  5. NOTIFY_RESULT   — 申报完成/失败，通知用户结果\n\"\"\"\n\nfrom shared import (\n    create_task, load_state, save_state, transition, fail,\n    list_tasks, output, parse_args, log, now_iso,\n)\nfrom login import ensure_logged_in\nfrom fetch_tax_list import fetch_tax_list\nfrom init_declaration import init_declaration\nfrom submit_declaration import submit_standard, submit_simplified\nfrom download_receipt import download_receipt\nfrom payment import execute_payment\n\n\ndef _parse_period(period_str: str) -> tuple[int, int]:\n    parts = period_str.split(\"-\")\n    return int(parts[0]), int(parts[1])\n\n\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n# 交互记录检查器\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\ndef _require_interaction(state: dict, interaction_id: str) -> bool:\n    \"\"\"\n    检查某个强制交互是否已完成。\n    返回 True = 已完成，可以继续\n    返回 False = 未完成，必须等用户\n    \"\"\"\n    interactions = state.get(\"interactions\", {})\n    record = interactions.get(interaction_id)\n    if not record:\n        return False\n    return record.get(\"completed\", False)\n\n\ndef _mark_interaction_required(state: dict, interaction_id: str, prompt: str) -> dict:\n    \"\"\"标记一个交互为\"等待中\"，记录发起时间\"\"\"\n    if \"interactions\" not in state:\n        state[\"interactions\"] = {}\n    if interaction_id not in state[\"interactions\"]:\n        state[\"interactions\"][interaction_id] = {\n            \"completed\": False,\n            \"required_at\": now_iso(),\n            \"prompt\": prompt,\n            \"user_response\": None,\n        }\n        save_state(state[\"task_id\"], state)\n    return state\n\n\ndef _complete_interaction(state: dict, interaction_id: str, user_response) -> dict:\n    \"\"\"标记交互完成，记录用户回复\"\"\"\n    if \"interactions\" not in state:\n        state[\"interactions\"] = {}\n    state[\"interactions\"][interaction_id] = {\n        \"completed\": True,\n        \"required_at\": state[\"interactions\"].get(interaction_id, {}).get(\"required_at\", now_iso()),\n        \"completed_at\": now_iso(),\n        \"user_response\": user_response,\n    }\n    save_state(state[\"task_id\"], state)\n    return state\n\n\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n# 状态处理器\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\ndef handle_INIT(state: dict) -> dict:\n    \"\"\"S01: 初始化 — 检查登录\"\"\"\n    agg_org_id = state[\"agg_org_id\"]\n    if not agg_org_id:\n        return _pause_llm(state, \"missing_agg_org_id\",\n                          \"缺少企业聚合ID，请向用户询问\")\n\n    login_result = ensure_logged_in(agg_org_id)\n    if not login_result[\"ok\"]:\n        if login_result.get(\"need_natural_person_login\"):\n            return _pause_llm(state, \"need_login\",\n                              \"税局登录已失效，请调用 qxy-login 完成登录\")\n        fail(state, login_result.get(\"error\", \"登录失败\"))\n        return state\n\n    return transition(state, \"FETCH_LIST\", \"logged_in\")\n\n\ndef handle_FETCH_LIST(state: dict) -> dict:\n    \"\"\"S02: 获取应申报清册\"\"\"\n    year, period_num = _parse_period(state[\"period\"])\n    result = fetch_tax_list(state[\"agg_org_id\"], year, period_num)\n\n    if not result[\"ok\"]:\n        fail(state, result.get(\"error\", \"获取清册失败\"))\n        if state[\"retry_count\"] >= state[\"max_retries\"]:\n            return transition(state, \"FAILED\", \"max_retries_exceeded\")\n        return state\n\n    state[\"data\"][\"tax_list\"] = result\n    save_state(state[\"task_id\"], state)\n    return transition(state, \"CHECK_REQUIRED\", \"ok\")\n\n\ndef handle_CHECK_REQUIRED(state: dict) -> dict:\n    \"\"\"S03: 判断是否需要申报 → 无论结果必须通知用户\"\"\"\n    tax_list = state[\"data\"].get(\"tax_list\", {})\n\n    if not tax_list.get(\"has_required\"):\n        # 无需申报 — 必须通知用户\n        return _pause_mandatory(state, \"notify_no_required\",\n            prompt=\"【必须通知用户】本月无需申报，请发送消息告知用户。\",\n            llm_context={\n                \"situation\": \"no_required\",\n                \"company_name\": state[\"company_name\"],\n                \"period\": state[\"period\"],\n                \"instruction\": (\n                    \"你必须发送消息告知用户：本月无需申报。\\n\"\n                    \"发送后 inject: data_key='notify_no_required' data_value={'user_notified': true}\"\n                ),\n            })\n\n    # 需要申报 — 必须通知用户税种清单并等用户确认\n    INTERACTION_ID = \"notify_taxes\"\n    if _require_interaction(state, INTERACTION_ID):\n        return transition(state, \"DATA_INIT\", \"user_confirmed_proceed\")\n\n    required = tax_list.get(\"required_items\", [])\n    _mark_interaction_required(state, INTERACTION_ID, \"通知用户需申报的税种清单\")\n\n    return _pause_mandatory(state, INTERACTION_ID,\n        prompt=\"【必须通知用户并等待确认】本月需要申报的税种清单。\",\n        llm_context={\n            \"situation\": \"report_required_taxes\",\n            \"required_items\": required,\n            \"required_count\": len(required),\n            \"instruction\": (\n                \"你必须向用户发送消息，告知本月需要申报的税种清单：\\n\"\n                + \"\\n\".join([f\"  - {item.get('zsxmMc', item.get('tax_code', '未知'))}\" for item in required])\n                + \"\\n\\n然后告知用户已启动申报流程。\\n\"\n                \"等用户回复确认后，inject: data_key='notify_taxes' data_value={'user_notified': true, 'user_response': '用户的原话'}\\n\"\n                \"⚠️ 禁止跳过此步骤，禁止自行假设用户已确认。\"\n            ),\n        })\n\n\ndef handle_DATA_INIT(state: dict) -> dict:\n    \"\"\"S04: 申报表数据初始化\"\"\"\n    year, period_num = _parse_period(state[\"period\"])\n    tax_list = state[\"data\"].get(\"tax_list\", {})\n    required_items = tax_list.get(\"required_items\", [])\n\n    result = init_declaration(state[\"agg_org_id\"], year, period_num, required_items)\n    state[\"data\"][\"init_data\"] = result\n    save_state(state[\"task_id\"], state)\n\n    if result.get(\"errors\"):\n        return _pause_llm(state, \"init_partial_failure\",\n            f\"部分税种初始化失败: {len(result['errors'])} 个错误，需分析原因\",\n            extra={\"errors\": result[\"errors\"], \"results\": result.get(\"results\", [])})\n\n    return transition(state, \"WAIT_UPLOAD\", \"ok\")\n\n\ndef handle_WAIT_UPLOAD(state: dict) -> dict:\n    \"\"\"S05: 等待用户上传 Excel — 强制交互，必须收到真实文件\"\"\"\n    INTERACTION_ID = \"upload_excel\"\n\n    if _require_interaction(state, INTERACTION_ID):\n        # 用户已上传，进入解析\n        return transition(state, \"PARSE_EXCEL\", \"file_received\")\n\n    _mark_interaction_required(state, INTERACTION_ID, \"等待用户上传 Excel\")\n\n    return {\n        **state,\n        \"_need_user_input\": True,\n        \"_mandatory_interaction\": INTERACTION_ID,\n        \"_prompt\": (\n            \"请向用户发送消息：请上传本月的申报数据 Excel 文件（仅支持 .xlsx 格式）。\\n\"\n            \"然后等待用户上传文件。\\n\"\n            \"收到文件后，inject: data_key='upload_excel' data_value={'file_received': true, 'file_path': '文件路径'}\\n\"\n            \"同时 inject: data_key='uploaded_excel' data_value={文件内容/路径}\\n\"\n            \"⚠️ 禁止跳过此步骤，禁止自行生成假数据替代用户上传。\"\n        ),\n        \"_waiting_for\": \"excel_upload\",\n    }\n\n\ndef handle_PARSE_EXCEL(state: dict) -> dict:\n    \"\"\"S06: 解析 Excel — LLM 环节\"\"\"\n    INTERACTION_ID = \"parse_result\"\n\n    if _require_interaction(state, INTERACTION_ID):\n        parsed = state[\"data\"].get(\"parsed_excel\")\n        if parsed:\n            return transition(state, \"CONFIRM_INCOME\", \"parsed\")\n        # 解析失败，要求重新上传\n        return transition(state, \"WAIT_UPLOAD\", \"parse_failed_reupload\")\n\n    _mark_interaction_required(state, INTERACTION_ID, \"Excel 解析\")\n\n    return _pause_mandatory(state, INTERACTION_ID,\n        prompt=\"解析用户上传的 Excel 文件\",\n        llm_context={\n            \"situation\": \"parse_excel\",\n            \"uploaded_excel\": state[\"data\"].get(\"uploaded_excel\"),\n            \"init_data\": state[\"data\"].get(\"init_data\"),\n            \"company_type\": state.get(\"company_type\", \"small_scale\"),\n            \"instruction\": (\n                \"解析用户上传的 Excel，将数据映射到税务局标准格式。\\n\"\n                \"解析成功后:\\n\"\n                \"  inject: data_key='parsed_excel' data_value={解析后的标准数据}\\n\"\n                \"  inject: data_key='parse_result' data_value={'completed': true, 'success': true}\\n\"\n                \"解析失败后:\\n\"\n                \"  必须发消息告诉用户失败原因，要求重新上传\\n\"\n                \"  inject: data_key='parse_result' data_value={'completed': true, 'success': false, 'error': '原因'}\\n\"\n            ),\n        })\n\n\ndef handle_CONFIRM_INCOME(state: dict) -> dict:\n    \"\"\"\n    S07: 询问用户是否有无票收入 — 强制交互\n    必须真正问用户，等用户回复，禁止自行假设\n    \"\"\"\n    INTERACTION_ID = \"confirm_income\"\n\n    if _require_interaction(state, INTERACTION_ID):\n        # 用户已回复，检查回复内容\n        record = state[\"interactions\"][INTERACTION_ID]\n        response = record.get(\"user_response\", {})\n\n        if isinstance(response, dict) and response.get(\"has_income\"):\n            # 用户说有无票收入\n            amount = response.get(\"amount\", 0)\n            if amount > 0:\n                parsed = state[\"data\"].get(\"parsed_excel\") or {}\n                vat = parsed.get(\"vat\") or {}\n                old_sales = vat.get(\"sales_amount\", 0)\n                vat[\"sales_amount\"] = old_sales + amount\n                vat[\"no_invoice_income\"] = amount\n                parsed[\"vat\"] = vat\n\n                cit = parsed.get(\"cit\") or {}\n                old_rev = cit.get(\"revenue\", 0)\n                cit[\"revenue\"] = old_rev + amount\n                cit[\"no_invoice_income\"] = amount\n                parsed[\"cit\"] = cit\n\n                state[\"data\"][\"parsed_excel\"] = parsed\n                save_state(state[\"task_id\"], state)\n                log.info(f\"[{state['task_id']}] 无票收入 ¥{amount} 已加入\")\n\n        return transition(state, \"TAX_CALC\", \"income_confirmed\")\n\n    # 还没问用户 → 必须问\n    _mark_interaction_required(state, INTERACTION_ID, \"询问无票收入\")\n    parsed = state[\"data\"].get(\"parsed_excel\") or {}\n    vat = parsed.get(\"vat\") or {}\n    current_sales = vat.get(\"sales_amount\", 0)\n\n    return _pause_mandatory(state, INTERACTION_ID,\n        prompt=\"必须询问用户是否有无票收入\",\n        llm_context={\n            \"situation\": \"confirm_no_invoice_income\",\n            \"current_sales\": current_sales,\n            \"instruction\": (\n                f\"你必须向用户发送消息询问：\\n\"\n                f\"\\\"当前已识别的销售额为 ¥{current_sales}，请问本期是否有无票收入需要补充？\\\"\\n\\n\"\n                \"然后等待用户回复。根据用户回复：\\n\"\n                \"- 用户说有（如'有，5万'）→ inject: data_key='confirm_income' \"\n                \"data_value={'completed': true, 'user_response': {'has_income': true, 'amount': 50000}}\\n\"\n                \"- 用户说没有 → inject: data_key='confirm_income' \"\n                \"data_value={'completed': true, 'user_response': {'has_income': false}}\\n\\n\"\n                \"⚠️ 你必须真正等用户回复，禁止自行假设用户回答'没有'。\\n\"\n                \"⚠️ 如果用户还没回复，不要进行任何 inject 操作。\"\n            ),\n        })\n\n\ndef handle_TAX_CALC(state: dict) -> dict:\n    \"\"\"S08: 税费计算（纯脚本，确定性）\"\"\"\n    # 如果已经计算过且交互已完成 → 直接推进到 SUBMIT\n    if state[\"data\"].get(\"calculated_taxes\"):\n        if _require_interaction(state, \"notify_zero_declare\") or \\\n           _require_interaction(state, \"confirm_tax_calc\"):\n            return transition(state, \"SUBMIT\", \"confirmed_proceed\")\n\n    from calculate_tax import calculate_tax\n\n    tax_list = state[\"data\"].get(\"tax_list\", {})\n    tax_codes = [item.get(\"yzpzzlDm\", item.get(\"tax_code\", \"\"))\n                 for item in tax_list.get(\"required_items\", [])]\n\n    result = calculate_tax(\n        declaration_data=state[\"data\"].get(\"parsed_excel\", {}),\n        tax_codes=tax_codes,\n        company_type=state.get(\"company_type\", \"small_scale\"),\n    )\n\n    state[\"data\"][\"calculated_taxes\"] = result\n    save_state(state[\"task_id\"], state)\n\n    if result.get(\"is_all_zero\"):\n        return _pause_mandatory(state, \"notify_zero_declare\",\n            prompt=\"通知用户本期为零申报\",\n            llm_context={\n                \"situation\": \"zero_declaration\",\n                \"instruction\": (\n                    \"向用户发送消息：本期所有税种应缴税额为 ¥0，将自动执行零申报。\\n\"\n                    \"通知后 inject: data_key='notify_zero_declare' \"\n                    \"data_value={'completed': true, 'user_notified': true}\\n\"\n                    \"然后 advance 继续。\"\n                ),\n            })\n\n    return _pause_mandatory(state, \"confirm_tax_calc\",\n        prompt=\"向用户展示税费计算结果并等待确认\",\n        llm_context={\n            \"situation\": \"show_tax_calculation\",\n            \"results\": result.get(\"results\", []),\n            \"total_payable\": result.get(\"total_payable\", 0),\n            \"instruction\": (\n                f\"向用户展示税费计算结果（应缴合计: ¥{result.get('total_payable', 0)}），\"\n                \"请用户确认无误后继续。\\n\"\n                \"用户确认后 inject: data_key='confirm_tax_calc' \"\n                \"data_value={'completed': true, 'user_confirmed': true}\\n\"\n                \"⚠️ 必须等用户确认，禁止自行跳过。\"\n            ),\n        })\n\n\ndef handle_SUBMIT(state: dict) -> dict:\n    \"\"\"S09: 提交申报\"\"\"\n    year, period_num = _parse_period(state[\"period\"])\n    agg_org_id = state[\"agg_org_id\"]\n    is_all_zero = state[\"data\"].get(\"calculated_taxes\", {}).get(\"is_all_zero\", False)\n    company_type = state.get(\"company_type\", \"small_scale\")\n\n    if is_all_zero and company_type in (\"small_scale\", \"general\"):\n        result = submit_simplified(agg_org_id, year, period_num, sb_init=True)\n    else:\n        report_data = state[\"data\"].get(\"parsed_excel\", {}).get(\"report_payload\", {})\n        result = submit_standard(agg_org_id, year, period_num, report_data)\n\n    state[\"data\"][\"submit_result\"] = result\n    save_state(state[\"task_id\"], state)\n\n    if not result[\"ok\"]:\n        error_type = result.get(\"error_type\", \"unknown\")\n        error_msg = result.get(\"error\", \"申报失败\")\n\n        if result.get(\"retryable\"):\n            fail(state, error_msg)\n            if state[\"retry_count\"] < state[\"max_retries\"]:\n                return state\n            return transition(state, \"FAILED\", \"max_retries_exceeded\")\n\n        # 失败 — 必须通知用户\n        return _pause_mandatory(state, \"notify_submit_fail\",\n            prompt=\"申报失败，必须通知用户\",\n            llm_context={\n                \"situation\": \"submit_failed\",\n                \"error\": error_msg, \"error_type\": error_type,\n                \"code\": result.get(\"code\"),\n                \"instruction\": (\n                    f\"申报失败 [{error_type}]: {error_msg}\\n\"\n                    \"你必须发消息告知用户申报失败的原因和建议操作。\\n\"\n                    \"通知后 inject: data_key='notify_submit_fail' \"\n                    \"data_value={'completed': true, 'user_notified': true}\"\n                ),\n            })\n\n    return transition(state, \"DOWNLOAD\", \"submitted\")\n\n\ndef handle_DOWNLOAD(state: dict) -> dict:\n    \"\"\"S10: 下载 PDF 回执\"\"\"\n    year, period_num = _parse_period(state[\"period\"])\n    tax_list = state[\"data\"].get(\"tax_list\", {})\n    required = tax_list.get(\"required_items\", [])\n\n    zsxm_list = [{\"yzpzzlDm\": item.get(\"yzpzzlDm\", \"\")}\n                 for item in required if item.get(\"yzpzzlDm\")]\n\n    result = download_receipt(state[\"agg_org_id\"], year, period_num, zsxm_list)\n\n    state[\"data\"][\"receipt_data\"] = result.get(\"structured_data\")\n    state[\"data\"][\"pdf_data\"] = result.get(\"pdf_data\")\n    save_state(state[\"task_id\"], state)\n\n    if not result[\"ok\"]:\n        log.warning(f\"PDF 下载失败: {result.get('error')}，但申报已成功\")\n\n    return transition(state, \"NOTIFY_COMPLETE\", \"ok\")\n\n\ndef handle_NOTIFY_COMPLETE(state: dict) -> dict:\n    \"\"\"S11: 通知用户申报完成 — 强制交互\"\"\"\n    INTERACTION_ID = \"notify_complete\"\n\n    if _require_interaction(state, INTERACTION_ID):\n        return transition(state, \"DONE\", \"user_notified\")\n\n    _mark_interaction_required(state, INTERACTION_ID, \"通知用户申报完成\")\n    taxes = state[\"data\"].get(\"calculated_taxes\", {})\n    receipt = state[\"data\"].get(\"receipt_data\")\n\n    return _pause_mandatory(state, INTERACTION_ID,\n        prompt=\"必须通知用户申报结果\",\n        llm_context={\n            \"situation\": \"declaration_complete\",\n            \"company_name\": state[\"company_name\"],\n            \"period\": state[\"period\"],\n            \"total_payable\": taxes.get(\"total_payable\", 0),\n            \"is_all_zero\": taxes.get(\"is_all_zero\", False),\n            \"has_pdf\": receipt is not None,\n            \"receipt_data\": receipt,\n            \"instruction\": (\n                f\"你必须向用户发送申报完成通知：\\n\"\n                f\"  企业: {state['company_name']}\\n\"\n                f\"  申报期: {state['period']}\\n\"\n                f\"  应缴税额: ¥{taxes.get('total_payable', 0)}\\n\"\n                f\"  {'零申报' if taxes.get('is_all_zero') else '非零申报'}\\n\"\n                + (\"  PDF回执已下载\\n\" if receipt else \"\")\n                + \"\\n通知后 inject: data_key='notify_complete' \"\n                \"data_value={'completed': true, 'user_notified': true}\\n\"\n                \"⚠️ 必须发送通知，禁止跳过。\"\n            ),\n        })\n\n\ndef handle_DONE(state: dict) -> dict:\n    \"\"\"S12: 完成\"\"\"\n    taxes = state[\"data\"].get(\"calculated_taxes\", {})\n    interactions = state.get(\"interactions\", {})\n\n    return {\n        **state,\n        \"_completed\": True,\n        \"_summary\": {\n            \"task_id\": state[\"task_id\"],\n            \"company_name\": state[\"company_name\"],\n            \"period\": state[\"period\"],\n            \"status\": \"completed\",\n            \"total_payable\": taxes.get(\"total_payable\", 0),\n            \"is_all_zero\": taxes.get(\"is_all_zero\", False),\n            \"interactions_completed\": {k: v.get(\"completed\") for k, v in interactions.items()},\n            \"message\": (\n                f\"{state['company_name']} {state['period']} 申报完成\"\n                + (f\"，应缴税额: ¥{taxes.get('total_payable', 0)}\"\n                   if not taxes.get(\"is_all_zero\") else \"（零申报）\")\n            ),\n        },\n    }\n\n\ndef handle_FAILED(state: dict) -> dict:\n    \"\"\"失败终态\"\"\"\n    interactions = state.get(\"interactions\", {})\n    return {\n        **state,\n        \"_completed\": True,\n        \"_failed\": True,\n        \"_summary\": {\n            \"task_id\": state[\"task_id\"],\n            \"company_name\": state[\"company_name\"],\n            \"period\": state[\"period\"],\n            \"status\": \"failed\",\n            \"error\": state.get(\"error\"),\n            \"interactions_completed\": {k: v.get(\"completed\") for k, v in interactions.items()},\n        },\n    }\n\n\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n# 暂停辅助函数\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\ndef _pause_mandatory(state: dict, interaction_id: str, prompt: str,\n                     llm_context: dict = None) -> dict:\n    \"\"\"暂停并要求强制交互\"\"\"\n    _mark_interaction_required(state, interaction_id, prompt)\n    return {\n        **state,\n        \"_need_llm\": True,\n        \"_mandatory_interaction\": interaction_id,\n        \"_llm_context\": llm_context or {\"instruction\": prompt},\n    }\n\n\ndef _pause_llm(state: dict, situation: str, message: str, extra: dict = None) -> dict:\n    \"\"\"暂停让 LLM 处理（非强制交互场景，如错误分析）\"\"\"\n    ctx = {\"situation\": situation, \"message\": message}\n    if extra:\n        ctx.update(extra)\n    return {**state, \"_need_llm\": True, \"_llm_context\": ctx}\n\n\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n# 状态映射 + 引擎\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\nHANDLERS = {\n    \"INIT\":            handle_INIT,\n    \"FETCH_LIST\":      handle_FETCH_LIST,\n    \"CHECK_REQUIRED\":  handle_CHECK_REQUIRED,\n    \"DATA_INIT\":       handle_DATA_INIT,\n    \"WAIT_UPLOAD\":     handle_WAIT_UPLOAD,\n    \"PARSE_EXCEL\":     handle_PARSE_EXCEL,\n    \"CONFIRM_INCOME\":  handle_CONFIRM_INCOME,\n    \"TAX_CALC\":        handle_TAX_CALC,\n    \"SUBMIT\":          handle_SUBMIT,\n    \"DOWNLOAD\":        handle_DOWNLOAD,\n    \"NOTIFY_COMPLETE\": handle_NOTIFY_COMPLETE,\n    \"DONE\":            handle_DONE,\n    \"FAILED\":          handle_FAILED,\n}\n\n\ndef advance(task_id: str) -> dict:\n    state = load_state(task_id)\n    if not state:\n        return {\"ok\": False, \"error\": f\"任务不存在: {task_id}\"}\n\n    max_steps = 20\n    steps = 0\n\n    while steps < max_steps:\n        steps += 1\n        current = state[\"state\"]\n        handler = HANDLERS.get(current)\n\n        if not handler:\n            return {\"ok\": False, \"error\": f\"未知状态: {current}\"}\n\n        log.info(f\"[{task_id}] 执行: {current}\")\n        state = handler(state)\n\n        # 需要 LLM / 用户交互 → 暂停\n        if state.get(\"_need_llm\") or state.get(\"_need_user_input\"):\n            interaction_id = state.get(\"_mandatory_interaction\")\n            return {\n                \"ok\": True,\n                \"paused\": True,\n                \"reason\": \"mandatory_interaction\" if interaction_id else \"need_llm\",\n                \"state\": state[\"state\"],\n                \"mandatory_interaction\": interaction_id,\n                \"llm_context\": state.get(\"_llm_context\"),\n                \"prompt\": state.get(\"_prompt\"),\n                \"task_id\": task_id,\n                \"interactions_status\": {\n                    k: v.get(\"completed\") for k, v in state.get(\"interactions\", {}).items()\n                },\n            }\n\n        # 完成\n        if state.get(\"_completed\"):\n            return {\n                \"ok\": True, \"completed\": True,\n                \"failed\": state.get(\"_failed\", False),\n                \"summary\": state.get(\"_summary\"),\n                \"task_id\": task_id,\n            }\n\n    return {\"ok\": False, \"error\": \"超过最大步数限制\", \"task_id\": task_id}\n\n\ndef inject_data(task_id: str, data_key: str, data_value) -> dict:\n    \"\"\"\n    注入数据。如果 data_key 匹配某个 interaction_id，自动标记交互完成。\n    \"\"\"\n    state = load_state(task_id)\n    if not state:\n        return {\"ok\": False, \"error\": f\"任务不存在: {task_id}\"}\n\n    # 写入数据\n    state[\"data\"][data_key] = data_value\n\n    # 检查是否是强制交互的回复\n    interactions = state.get(\"interactions\", {})\n    if data_key in interactions:\n        # 验证 data_value 合法性\n        if isinstance(data_value, dict) and data_value.get(\"completed\"):\n            _complete_interaction(state, data_key, data_value)\n            log.info(f\"[{task_id}] ✅ 强制交互完成: {data_key}\")\n        else:\n            log.warning(f\"[{task_id}] inject {data_key} 但缺少 completed=true，交互未标记完成\")\n\n    save_state(task_id, state)\n    return {\"ok\": True, \"message\": f\"已注入: {data_key}\", \"task_id\": task_id,\n            \"interaction_completed\": data_key in interactions}\n\n\ndef force_transition(task_id: str, new_state: str) -> dict:\n    state = load_state(task_id)\n    if not state:\n        return {\"ok\": False, \"error\": f\"任务不存在: {task_id}\"}\n    if new_state not in HANDLERS:\n        return {\"ok\": False, \"error\": f\"无效状态: {new_state}\"}\n    transition(state, new_state, \"forced_by_agent\")\n    return {\"ok\": True, \"message\": f\"已转移到: {new_state}\", \"task_id\": task_id}\n\n\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n# CLI\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\nif __name__ == \"__main__\":\n    args = parse_args()\n    action = args.get(\"action\", \"status\")\n\n    if action == \"create\":\n        state = create_task(\n            company_id=args[\"company_id\"],\n            company_name=args[\"company_name\"],\n            period=args[\"period\"],\n            agg_org_id=str(args.get(\"agg_org_id\", args.get(\"aggOrgId\", \"\"))),\n            company_type=args.get(\"company_type\", \"small_scale\"),\n        )\n        output({\"ok\": True, \"task_id\": state[\"task_id\"], \"state\": state[\"state\"]})\n\n    elif action == \"advance\":\n        result = advance(args[\"task_id\"])\n        output(result)\n\n    elif action == \"status\":\n        state = load_state(args.get(\"task_id\", \"\"))\n        if state:\n            output({\n                \"ok\": True,\n                \"task_id\": state[\"task_id\"],\n                \"state\": state[\"state\"],\n                \"company_name\": state[\"company_name\"],\n                \"period\": state[\"period\"],\n                \"interactions\": {\n                    k: {\"completed\": v.get(\"completed\"), \"required_at\": v.get(\"required_at\")}\n                    for k, v in state.get(\"interactions\", {}).items()\n                },\n                \"last_updated\": state[\"updated_at\"],\n            })\n        else:\n            output({\"ok\": False, \"error\": \"任务不存在\"})\n\n    elif action == \"inject\":\n        result = inject_data(args[\"task_id\"], args[\"data_key\"], args[\"data_value\"])\n        output(result)\n\n    elif action == \"force_transition\":\n        result = force_transition(args[\"task_id\"], args[\"new_state\"])\n        output(result)\n\n    elif action == \"list\":\n        tasks = list_tasks(args.get(\"status_filter\"))\n        output({\n            \"ok\": True,\n            \"tasks\": [{\n                \"task_id\": t[\"task_id\"],\n                \"company_name\": t[\"company_name\"],\n                \"period\": t[\"period\"],\n                \"state\": t[\"state\"],\n                \"interactions\": {\n                    k: v.get(\"completed\") for k, v in t.get(\"interactions\", {}).items()\n                },\n            } for t in tasks],\n            \"count\": len(tasks),\n        })\n\n    else:\n        output({\"ok\": False, \"error\": f\"未知 action: {action}\"})\n"}],"isError":false,"timestamp":1773822979725}}
{"type":"message","id":"50373d70","parentId":"bca4c615","timestamp":"2026-03-18T08:36:21.982Z","message":{"role":"assistant","content":[{"type":"text","text":"现在我明白了系统架构。让我检查是否存在现有任务或状态文件，并验证 `mock server` 是否在运行："},{"type":"toolCall","id":"call_5d5e1beacfe0455b8a71b861","name":"exec","arguments":{"command":"ls -la /Users/kristyzhang/.openclaw/workspace-qxy-declare/states/"}},{"type":"toolCall","id":"call_70233e62514549ab980ff226","name":"exec","arguments":{"command":"curl -s http://localhost:18800/ 2>&1 | head -20"}}],"api":"openai-completions","provider":"zai","model":"glm-5-turbo","usage":{"input":7498,"output":80,"cacheRead":19574,"cacheWrite":0,"totalTokens":27152,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773822979727}}
