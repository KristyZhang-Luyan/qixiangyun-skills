{"type":"message","id":"bcb1bdff","parentId":"aec1fdd5","timestamp":"2026-03-18T08:36:22.110Z","message":{"role":"toolResult","toolCallId":"call_70233e62514549ab980ff226","toolName":"exec","content":[{"type":"text","text":"{\"reqId\": \"a346ccad04a74cebc52ed2ab04afedaa\", \"code\": \"SUCCESS\", \"success\": true, \"data\": {}, \"message\": \"mock: unmatched path /\"}"}],"details":{"status":"completed","exitCode":0,"durationMs":61,"aggregated":"{\"reqId\": \"a346ccad04a74cebc52ed2ab04afedaa\", \"code\": \"SUCCESS\", \"success\": true, \"data\": {}, \"message\": \"mock: unmatched path /\"}","cwd":"/Users/kristyzhang/.openclaw/workspace-qxy-declare"},"isError":false,"timestamp":1773822982107}}
{"type":"message","id":"7ea6171d","parentId":"bcb1bdff","timestamp":"2026-03-18T08:36:25.214Z","message":{"role":"assistant","content":[{"type":"text","text":"Mock server 正在运行。状态目录为空，所以我需要从头开始创建任务。我还要检查 `login.py` 和 `shared.py`，以了解认证在模拟模式下是如何工作的："},{"type":"toolCall","id":"call_7a1acba635034109a6856bb9","name":"read","arguments":{"path":"/Users/kristyzhang/.openclaw/agents/qxy-declare/agent/tools/login.py"}},{"type":"toolCall","id":"call_5639cac09e75425faca00e89","name":"read","arguments":{"path":"/Users/kristyzhang/.openclaw/agents/qxy-declare/agent/tools/shared.py"}}],"api":"openai-completions","provider":"zai","model":"glm-5-turbo","usage":{"input":9141,"output":97,"cacheRead":18125,"cacheWrite":0,"totalTokens":27363,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773822982111}}
{"type":"message","id":"bf55bd80","parentId":"7ea6171d","timestamp":"2026-03-18T08:36:25.228Z","message":{"role":"toolResult","toolCallId":"call_7a1acba635034109a6856bb9","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nlogin — 登录相关工具\n对应企享云接口:\n  - check_quick_login (api-164618489): 校验是否可快速登录\n  - login_tax_bureau (api-164576229): 登录税局\n\"\"\"\n\nfrom shared import api_call, output, parse_args, log\n\n\ndef check_login_status(agg_org_id: str) -> dict:\n    \"\"\"检查当前企业是否可快速登录税局\"\"\"\n    result = api_call(\"check_quick_login\", payload={\n        \"aggOrgId\": agg_org_id,\n    })\n\n    if not result[\"ok\"]:\n        return {\n            \"ok\": False,\n            \"can_quick_login\": False,\n            \"error\": result.get(\"error\"),\n            \"need_relogin\": True,\n        }\n\n    data = result[\"data\"]\n    can_login = data.get(\"data\", data).get(\"canQuickLogin\",\n                data.get(\"data\", data).get(\"result\", False))\n\n    return {\n        \"ok\": True,\n        \"can_quick_login\": bool(can_login),\n        \"need_relogin\": not bool(can_login),\n    }\n\n\ndef login_tax_bureau(agg_org_id: str) -> dict:\n    \"\"\"登录税局\"\"\"\n    result = api_call(\"login_tax_bureau\", payload={\n        \"aggOrgId\": agg_org_id,\n    })\n\n    if not result[\"ok\"]:\n        return {\n            \"ok\": False,\n            \"error\": result.get(\"error\", result.get(\"message\")),\n            \"code\": result.get(\"code\"),\n        }\n\n    return {\n        \"ok\": True,\n        \"message\": \"税局登录成功\",\n        \"data\": result.get(\"data\"),\n    }\n\n\ndef ensure_logged_in(agg_org_id: str) -> dict:\n    \"\"\"确保已登录（检查 + 自动登录）\"\"\"\n    check = check_login_status(agg_org_id)\n\n    if check.get(\"can_quick_login\"):\n        login_result = login_tax_bureau(agg_org_id)\n        return login_result\n\n    if check.get(\"need_relogin\"):\n        return {\n            \"ok\": False,\n            \"error\": \"需要重新登录自然人\",\n            \"need_natural_person_login\": True,\n        }\n\n    return {\"ok\": True, \"message\": \"登录状态有效\"}\n\n\nif __name__ == \"__main__\":\n    args = parse_args()\n    action = args.get(\"action\", \"ensure\")\n    agg_org_id = str(args.get(\"agg_org_id\", args.get(\"aggOrgId\", \"\")))\n\n    if action == \"check\":\n        result = check_login_status(agg_org_id)\n    elif action == \"login\":\n        result = login_tax_bureau(agg_org_id)\n    else:\n        result = ensure_logged_in(agg_org_id)\n    output(result)\n"}],"isError":false,"timestamp":1773822985224}}
{"type":"message","id":"174828e7","parentId":"bf55bd80","timestamp":"2026-03-18T08:36:25.242Z","message":{"role":"toolResult","toolCallId":"call_5639cac09e75425faca00e89","toolName":"read","content":[{"type":"text","text":"\"\"\"\n共享工具库 — 企享云 API 适配\n核心特点：所有业务接口都是异步的（发起任务 → 轮询 taskId → 拿结果）\n\"\"\"\n\nimport json\nimport os\nimport sys\nimport time\nimport logging\nfrom pathlib import Path\nfrom datetime import datetime, timezone\n\nimport requests\n\n# ── 日志 ──────────────────────────────────────────────\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(name)s] %(levelname)s %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"qxy\")\n\n# ── 配置 ──────────────────────────────────────────────\nCONFIG_PATH = Path(__file__).parent / \"config.json\"\n\ndef load_config() -> dict:\n    with open(CONFIG_PATH) as f:\n        return json.load(f)\n\nCFG = load_config()\nBASE_URL = CFG[\"base_url\"].rstrip(\"/\")\nENDPOINTS = CFG[\"endpoints\"]\nTIMEOUT = CFG.get(\"timeout\", 30)\nRETRY_MAX = CFG.get(\"retry_max\", 3)\nRETRY_BACKOFF = CFG.get(\"retry_backoff\", 2)\n\nPOLL_CFG = CFG.get(\"task_polling\", {})\nPOLL_INTERVAL = POLL_CFG.get(\"interval_seconds\", 10)\nPOLL_MAX = POLL_CFG.get(\"max_attempts\", 30)\nSTATUS_FIELD = POLL_CFG.get(\"status_field\", \"business_status\")\nSTATUS_PROCESSING = POLL_CFG.get(\"status_values\", {}).get(\"processing\", 1)\nSTATUS_FAILED = POLL_CFG.get(\"status_values\", {}).get(\"failed\", 2)\nSTATUS_COMPLETED = POLL_CFG.get(\"status_values\", {}).get(\"completed\", 3)\n\nSTATE_DIR = Path(CFG.get(\"state_dir\", \"/tmp/qxy-declare-states\"))\nSTATE_DIR.mkdir(parents=True, exist_ok=True)\n\n# ── 认证 ──────────────────────────────────────────────\n_token_cache = {\"token\": None, \"expires_at\": 0}\n\ndef _get_token() -> str:\n    \"\"\"获取 API token，支持缓存\"\"\"\n    now = time.time()\n    if _token_cache[\"token\"] and now < _token_cache[\"expires_at\"]:\n        return _token_cache[\"token\"]\n\n    # 从环境变量取预设 token\n    env_token = os.environ.get(CFG.get(\"auth\", {}).get(\"token_env\", \"\"), \"\")\n    if env_token:\n        _token_cache[\"token\"] = env_token\n        _token_cache[\"expires_at\"] = now + 15 * 86400  # 15 天\n        return env_token\n\n    log.warning(\"未设置 API Token，请设置环境变量 QXY_API_TOKEN\")\n    return \"\"\n\ndef _get_headers() -> dict:\n    token = _get_token()\n    headers = {\"Content-Type\": \"application/json\"}\n    if token:\n        headers[\"Authorization\"] = f\"Bearer {token}\"\n    return headers\n\n# ── HTTP 请求（带重试） ───────────────────────────────\ndef api_call(endpoint_key: str, method: str = \"POST\", payload: dict = None,\n             raw_url: str = None) -> dict:\n    \"\"\"\n    调用企享云 API。\n    返回 {\"ok\": True/False, \"data\": ..., \"code\": ..., \"message\": ...}\n    \"\"\"\n    if raw_url:\n        url = raw_url\n    else:\n        path = ENDPOINTS.get(endpoint_key, endpoint_key)\n        if path.startswith(\"http\"):\n            url = path\n        elif path.startswith(\"/api-\"):\n            url = f\"{BASE_URL}{path}\"\n        else:\n            url = f\"{BASE_URL}{path}\"\n\n    headers = _get_headers()\n\n    for attempt in range(1, RETRY_MAX + 1):\n        try:\n            if method.upper() == \"GET\":\n                resp = requests.get(url, params=payload, headers=headers, timeout=TIMEOUT)\n            else:\n                resp = requests.post(url, json=payload, headers=headers, timeout=TIMEOUT)\n\n            if resp.status_code == 401:\n                # Token 失效\n                _token_cache[\"token\"] = None\n                return {\"ok\": False, \"error\": \"token_expired\", \"code\": 401,\n                        \"message\": \"Token 已失效，需要重新鉴权\"}\n\n            if resp.status_code == 200:\n                data = resp.json()\n                code = str(data.get(\"code\", \"\"))\n                success = data.get(\"success\", False)\n\n                if code in (\"2000\", \"SUCCESS\") or success:\n                    return {\"ok\": True, \"data\": data, \"code\": code, \"message\": data.get(\"message\", \"\")}\n                else:\n                    return {\n                        \"ok\": False,\n                        \"data\": data,\n                        \"code\": code,\n                        \"message\": data.get(\"message\", data.get(\"msg\", \"\")),\n                        \"error\": data.get(\"message\", data.get(\"msg\", f\"业务错误: code={code}\")),\n                    }\n\n            error_msg = f\"HTTP {resp.status_code}: {resp.text[:500]}\"\n            log.warning(f\"[{endpoint_key}] attempt {attempt}/{RETRY_MAX}: {error_msg}\")\n\n            if resp.status_code >= 500 and attempt < RETRY_MAX:\n                time.sleep(RETRY_BACKOFF ** attempt)\n                continue\n\n            return {\"ok\": False, \"error\": error_msg, \"code\": resp.status_code}\n\n        except requests.exceptions.Timeout:\n            log.warning(f\"[{endpoint_key}] attempt {attempt}/{RETRY_MAX}: timeout\")\n            if attempt < RETRY_MAX:\n                time.sleep(RETRY_BACKOFF ** attempt)\n                continue\n            return {\"ok\": False, \"error\": \"timeout\"}\n\n        except requests.exceptions.ConnectionError as e:\n            log.warning(f\"[{endpoint_key}] attempt {attempt}/{RETRY_MAX}: connection error\")\n            if attempt < RETRY_MAX:\n                time.sleep(RETRY_BACKOFF ** attempt)\n                continue\n            return {\"ok\": False, \"error\": f\"connection_error: {e}\"}\n\n        except Exception as e:\n            log.error(f\"[{endpoint_key}] unexpected error: {e}\")\n            return {\"ok\": False, \"error\": str(e)}\n\n    return {\"ok\": False, \"error\": \"max_retries_exceeded\"}\n\n\n# ── 异步任务轮询（企享云核心模式） ────────────────────\ndef poll_task(agg_org_id: str | int, task_id: str | int,\n              interval: int = None, max_attempts: int = None,\n              result_endpoint: str = None) -> dict:\n    \"\"\"\n    轮询异步任务结果。企享云所有业务接口都是这个模式：\n    1. 发起任务 → 拿到 taskId\n    2. 每 10 秒调 queryTaskInfo 查 business_status\n    3. status=3 完成，status=2 失败，status=1 进行中\n\n    Args:\n        agg_org_id: 企业聚合ID\n        task_id: 任务ID\n        interval: 轮询间隔（默认 10 秒）\n        max_attempts: 最大轮询次数（默认 30）\n        result_endpoint: 如需调用特定接口获取详细结果（如 querySimplifiedDeclareTaskInfo）\n\n    Returns:\n        {\"ok\": True/False, \"status\": \"completed/failed/processing\", \"data\": ...}\n    \"\"\"\n    interval = interval or POLL_INTERVAL\n    max_attempts = max_attempts or POLL_MAX\n\n    for i in range(1, max_attempts + 1):\n        result = api_call(\"query_task_info\", payload={\n            \"aggOrgId\": agg_org_id,\n            \"taskId\": task_id,\n        })\n\n        if not result[\"ok\"]:\n            log.warning(f\"轮询第 {i}/{max_attempts} 次失败: {result.get('error')}\")\n            if i < max_attempts:\n                time.sleep(interval)\n                continue\n            return {\n                \"ok\": False,\n                \"status\": \"error\",\n                \"error\": result.get(\"error\"),\n                \"poll_attempts\": i,\n            }\n\n        data = result[\"data\"]\n        # business_status 可能在 data 顶层或嵌套的 data 里\n        biz_data = data.get(\"data\", data)\n        status = biz_data.get(STATUS_FIELD, biz_data.get(\"businessStatus\"))\n\n        if status == STATUS_COMPLETED:\n            # 任务完成，如有特定结果接口则再调一次\n            if result_endpoint:\n                detail = api_call(result_endpoint, payload={\n                    \"aggOrgId\": agg_org_id,\n                    \"taskId\": task_id,\n                })\n                if detail[\"ok\"]:\n                    return {\n                        \"ok\": True,\n                        \"status\": \"completed\",\n                        \"data\": detail[\"data\"],\n                        \"poll_attempts\": i,\n                    }\n                else:\n                    return {\n                        \"ok\": True,\n                        \"status\": \"completed\",\n                        \"data\": data,\n                        \"detail_error\": detail.get(\"error\"),\n                        \"poll_attempts\": i,\n                    }\n\n            return {\n                \"ok\": True,\n                \"status\": \"completed\",\n                \"data\": data,\n                \"poll_attempts\": i,\n            }\n\n        elif status == STATUS_FAILED:\n            error_msg = biz_data.get(\"message\", biz_data.get(\"msg\", \"任务失败\"))\n            return {\n                \"ok\": False,\n                \"status\": \"failed\",\n                \"data\": data,\n                \"error\": error_msg,\n                \"poll_attempts\": i,\n            }\n\n        # 进行中，继续轮询\n        log.info(f\"轮询第 {i}/{max_attempts} 次，状态: processing (business_status={status})\")\n        if i < max_attempts:\n            time.sleep(interval)\n\n    return {\n        \"ok\": False,\n        \"status\": \"processing\",\n        \"error\": f\"轮询 {max_attempts} 次后仍在处理中\",\n        \"poll_attempts\": max_attempts,\n    }\n\n\n# ── 状态持久化 ────────────────────────────────────────\ndef _state_path(task_id: str) -> Path:\n    return STATE_DIR / f\"{task_id}.json\"\n\ndef now_iso() -> str:\n    return datetime.now(timezone.utc).isoformat()\n\ndef create_task(company_id: str, company_name: str, period: str,\n                agg_org_id: str = \"\", company_type: str = \"small_scale\") -> dict:\n    task_id = f\"decl_{period.replace('-', '')}_{company_id}\"\n    state = {\n        \"task_id\": task_id,\n        \"company_id\": company_id,\n        \"company_name\": company_name,\n        \"agg_org_id\": agg_org_id,\n        \"company_type\": company_type,\n        \"period\": period,\n        \"state\": \"INIT\",\n        \"state_history\": [],\n        \"data\": {\n            \"tax_list\": None,\n            \"declaration_forms\": None,\n            \"init_data\": None,\n            \"parsed_excel\": None,\n            \"user_confirmations\": None,\n            \"calculated_taxes\": None,\n            \"policy_matches\": None,\n            \"validation_result\": None,\n            \"submit_result\": None,\n            \"receipt_url\": None,\n            \"receipt_data\": None,\n        },\n        \"interactions\": {},\n        \"retry_count\": 0,\n        \"max_retries\": 3,\n        \"error\": None,\n        \"created_at\": now_iso(),\n        \"updated_at\": now_iso(),\n    }\n    save_state(task_id, state)\n    return state\n\ndef load_state(task_id: str) -> dict | None:\n    p = _state_path(task_id)\n    if not p.exists():\n        return None\n    with open(p) as f:\n        return json.load(f)\n\ndef save_state(task_id: str, state: dict):\n    state[\"updated_at\"] = now_iso()\n    with open(_state_path(task_id), \"w\") as f:\n        json.dump(state, f, ensure_ascii=False, indent=2)\n\ndef transition(state: dict, new_state: str, result: str = \"ok\") -> dict:\n    state[\"state_history\"].append({\n        \"state\": state[\"state\"],\n        \"at\": now_iso(),\n        \"result\": result,\n    })\n    state[\"state\"] = new_state\n    state[\"retry_count\"] = 0\n    state[\"error\"] = None\n    save_state(state[\"task_id\"], state)\n    log.info(f\"[{state['task_id']}] {state['state_history'][-1]['state']} → {new_state} ({result})\")\n    return state\n\ndef fail(state: dict, error: str) -> dict:\n    state[\"error\"] = error\n    state[\"retry_count\"] += 1\n    save_state(state[\"task_id\"], state)\n    log.error(f\"[{state['task_id']}] FAILED at {state['state']}: {error} (retry {state['retry_count']})\")\n    return state\n\ndef list_tasks(status_filter: str = None) -> list:\n    tasks = []\n    for f in STATE_DIR.glob(\"*.json\"):\n        with open(f) as fh:\n            task = json.load(fh)\n            if status_filter is None or task[\"state\"] == status_filter:\n                tasks.append(task)\n    return tasks\n\n# ── 输出 / 解析 ──────────────────────────────────────\ndef output(result: dict):\n    print(json.dumps(result, ensure_ascii=False, indent=2))\n\ndef parse_args() -> dict:\n    if not sys.stdin.isatty():\n        raw = sys.stdin.read().strip()\n        if raw:\n            return json.loads(raw)\n    if len(sys.argv) > 1:\n        return json.loads(sys.argv[1])\n    return {}\n"}],"isError":false,"timestamp":1773822985235}}
