n    \"load_payment_task\":            \"/api-67662292\",\n    \"query_payment_result\":         \"/api-67976986\",\n\n    \"load_wszm_task\":               \"/api-67648072\",\n    \"query_wszm_result\":            \"/api-79797899\"\n  },\n\n  \"mcp_servers\": {\n    \"roster_entry\":         \"https://mcp.qixiangyun.com/mcp/roster_entry-http\",\n    \"task_query\":           \"https://mcp.qixiangyun.com/mcp/task_query-http\",\n    \"task_execution\":       \"https://mcp.qixiangyun.com/mcp/task_execution-http\",\n    \"enterprise_management\":\"https://mcp.qixiangyun.com/mcp/enterprise_management-http\",\n    \"financial_report\":     \"https://mcp.qixiangyun.com/mcp/financial_report-http\",\n    \"financial_report_result\":\"https://mcp.qixiangyun.com/mcp/financial_report_result-http\",\n    \"tax_report_upload\":    \"https://mcp.qixiangyun.com/mcp/tax_report_upload-http\",\n    \"tax_report_result\":    \"https://mcp.qixiangyun.com/mcp/tax_report_result-http\",\n    \"initialize_data\":      \"https://mcp.qixiangyun.com/mcp/initialize_data-http\",\n    \"missing_declaration\":  \"https://mcp.qixiangyun.com/mcp/missing_declaration_check-http\",\n    \"tax_payment_certificate\":\"https://mcp.qixiangyun.com/mcp/tax_payment_certificate-http\"\n  },\n\n  \"task_polling\": {\n    \"interval_seconds\": 10,\n    \"max_attempts\": 30,\n    \"status_field\": \"business_status\",\n    \"status_values\": {\n      \"processing\": 1,\n      \"failed\": 2,\n      \"completed\": 3\n    }\n  },\n\n  \"auth\": {\n    \"type\": \"bearer\",\n    \"token_env\": \"QXY_API_TOKEN\",\n    \"token_cache_days\": 15\n  },\n\n  \"state_dir\": \"/Users/kristyzhang/.openclaw/workspace-qxy-declare/states\"\n}\n"}],"isError":false,"timestamp":1773822637350}}
