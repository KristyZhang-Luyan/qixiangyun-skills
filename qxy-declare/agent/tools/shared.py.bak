"""
共享工具库 — 企享云 API 适配
核心特点：所有业务接口都是异步的（发起任务 → 轮询 taskId → 拿结果）
签名规则：req_sign = API-SV1:<AppKey>:Base64(MD5(POST_MD5(body)_req_date_access_token_AppSecret))
"""

import json
import os
import sys
import time
import hashlib
import base64
import logging
from pathlib import Path
from datetime import datetime, timezone

import requests

# ── 日志 ──────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(name)s] %(levelname)s %(message)s",
    datefmt="%H:%M:%S",
)
log = logging.getLogger("qxy")

# ── 配置 ──────────────────────────────────────────────
CONFIG_PATH = Path(__file__).parent / "config.json"

def load_config() -> dict:
    with open(CONFIG_PATH) as f:
        return json.load(f)

CFG = load_config()
BASE_URL = CFG["base_url"].rstrip("/")
ENDPOINTS = CFG["endpoints"]
TIMEOUT = CFG.get("timeout", 30)
RETRY_MAX = CFG.get("retry_max", 3)
RETRY_BACKOFF = CFG.get("retry_backoff", 2)

POLL_CFG = CFG.get("task_polling", {})
POLL_INTERVAL = POLL_CFG.get("interval_seconds", 10)
POLL_MAX = POLL_CFG.get("max_attempts", 30)
STATUS_FIELD = POLL_CFG.get("status_field", "business_status")
STATUS_PROCESSING = POLL_CFG.get("status_values", {}).get("processing", 1)
STATUS_FAILED = POLL_CFG.get("status_values", {}).get("failed", 2)
STATUS_COMPLETED = POLL_CFG.get("status_values", {}).get("completed", 3)

STATE_DIR = Path(CFG.get("state_dir", "/tmp/qxy-declare-states"))
STATE_DIR.mkdir(parents=True, exist_ok=True)

# ── 签名与认证 ────────────────────────────────────────

AUTH_CFG = CFG.get("auth", {})
APP_KEY = AUTH_CFG.get("appkey", "") or os.environ.get("QXY_CLIENT_APPKEY", "")
APP_SECRET = AUTH_CFG.get("secret", "") or os.environ.get("QXY_CLIENT_SECRET", "")

_token_cache = {"token": None, "expires_at": 0}


def _md5(s: str) -> str:
    return hashlib.md5(s.encode("utf-8")).hexdigest()


def _make_sign(body_str: str, req_date: str, access_token: str) -> str:
    """生成 req_sign: API-SV1:<AppKey>:Base64(MD5(POST_MD5(body)_reqDate_token_AppSecret))"""
    content_md5 = _md5(body_str)
    to_sign = f"POST_{content_md5}_{req_date}_{access_token}_{APP_SECRET}"
    md5_result = _md5(to_sign)
    b64_result = base64.b64encode(md5_result.encode("utf-8")).decode("utf-8")
    return f"API-SV1:{APP_KEY}:{b64_result}"


def _fetch_token_from_api() -> str:
    """调用 /v2/public/oauth2/login 获取 access_token（client_secret 需传 MD5）"""
    url = f"{BASE_URL}/v2/public/oauth2/login"
    body = {
        "grant_type": "client_credentials",
        "client_appkey": APP_KEY,
        "client_secret": _md5(APP_SECRET),
    }
    try:
        resp = requests.post(url, json=body,
                             headers={"Content-Type": "application/json;charset=UTF-8"},
                             timeout=TIMEOUT)
        if resp.status_code == 200:
            data = resp.json()
            token = (data.get("data") or {}).get("access_token", "")
            if token:
                return token
            error_msg = (data.get("data") or {}).get("error_msg", data.get("message", ""))
            log.error("鉴权返回无 token: %s", error_msg or data)
        else:
            log.error("鉴权接口 HTTP %d: %s", resp.status_code, resp.text[:500])
    except Exception as e:
        log.error("鉴权接口调用异常: %s", e)
    return ""


def _get_token() -> str:
    """获取 access_token，带内存缓存"""
    now = time.time()
    if _token_cache["token"] and now < _token_cache["expires_at"]:
        return _token_cache["token"]

    if not APP_KEY or not APP_SECRET:
        log.warning("未配置企享云凭证，请在 config.json auth 中填写 appkey 和 secret")
        return ""

    token = _fetch_token_from_api()
    if token:
        cache_days = AUTH_CFG.get("token_cache_days", 15)
        _token_cache["token"] = token
        _token_cache["expires_at"] = now + cache_days * 86400
        log.info("鉴权成功，token 已缓存 %d 天", cache_days)
        return token

    log.error("鉴权失败，无法获取 token")
    return ""


def _build_signed_headers(body_str: str) -> dict:
    """构建带签名的请求头：access_token + req_date + req_sign"""
    token = _get_token()
    req_date = str(int(time.time() * 1000))
    headers = {"Content-Type": "application/json;charset=UTF-8"}
    if token:
        headers["access_token"] = token
        headers["req_date"] = req_date
        headers["req_sign"] = _make_sign(body_str, req_date, token)
    return headers

# ── HTTP 请求（带签名 + 重试） ─────────────────────────
def api_call(endpoint_key: str, method: str = "POST", payload: dict = None,
             raw_url: str = None) -> dict:
    """
    调用企享云 API（自动签名）。
    返回 {"ok": True/False, "data": ..., "code": ..., "message": ...}
    """
    if raw_url:
        url = raw_url
    else:
        path = ENDPOINTS.get(endpoint_key, endpoint_key)
        url = path if path.startswith("http") else f"{BASE_URL}{path}"

    body_str = json.dumps(payload or {}, ensure_ascii=False, separators=(",", ":"))

    for attempt in range(1, RETRY_MAX + 1):
        try:
            headers = _build_signed_headers(body_str)
            resp = requests.post(url, data=body_str.encode("utf-8"),
                                 headers=headers, timeout=TIMEOUT)

            if resp.status_code == 401:
                _token_cache["token"] = None
                _token_cache["expires_at"] = 0
                if attempt < RETRY_MAX:
                    log.warning("Token 失效(401)，重新鉴权后重试...")
                    time.sleep(1)
                    continue
                return {"ok": False, "error": "token_expired", "code": 401,
                        "message": "Token 已失效，重新鉴权仍失败"}

            if resp.status_code == 200:
                data = resp.json()
                code = str(data.get("code", ""))
                success = data.get("success", False)

                if code in ("2000", "SUCCESS") or success:
                    return {"ok": True, "data": data, "code": code, "message": data.get("message", "")}

                err = data.get("error", {})
                if isinstance(err, dict) and err.get("code") == "40100":
                    _token_cache["token"] = None
                    _token_cache["expires_at"] = 0
                    if attempt < RETRY_MAX:
                        log.warning("返回 40100 未登录，重新鉴权后重试...")
                        time.sleep(1)
                        continue

                return {
                    "ok": False, "data": data, "code": code,
                    "message": data.get("message", data.get("msg", "")),
                    "error": data.get("message", data.get("msg", f"业务错误: code={code}")),
                }

            error_msg = f"HTTP {resp.status_code}: {resp.text[:500]}"
            log.warning("[%s] attempt %d/%d: %s", endpoint_key, attempt, RETRY_MAX, error_msg)

            if resp.status_code >= 500 and attempt < RETRY_MAX:
                time.sleep(RETRY_BACKOFF ** attempt)
                continue

            return {"ok": False, "error": error_msg, "code": resp.status_code}

        except requests.exceptions.Timeout:
            log.warning("[%s] attempt %d/%d: timeout", endpoint_key, attempt, RETRY_MAX)
            if attempt < RETRY_MAX:
                time.sleep(RETRY_BACKOFF ** attempt)
                continue
            return {"ok": False, "error": "timeout"}

        except requests.exceptions.ConnectionError as e:
            log.warning("[%s] attempt %d/%d: connection error", endpoint_key, attempt, RETRY_MAX)
            if attempt < RETRY_MAX:
                time.sleep(RETRY_BACKOFF ** attempt)
                continue
            return {"ok": False, "error": f"connection_error: {e}"}

        except Exception as e:
            log.error("[%s] unexpected error: %s", endpoint_key, e)
            return {"ok": False, "error": str(e)}

    return {"ok": False, "error": "max_retries_exceeded"}


# ── 异步任务轮询（企享云核心模式） ────────────────────
def poll_task(agg_org_id: str | int, task_id: str | int,
              interval: int = None, max_attempts: int = None,
              result_endpoint: str = None) -> dict:
    """
    轮询异步任务结果。企享云所有业务接口都是这个模式：
    1. 发起任务 → 拿到 taskId
    2. 每 10 秒调 queryTaskInfo 查 business_status
    3. status=3 完成，status=2 失败，status=1 进行中

    Args:
        agg_org_id: 企业聚合ID
        task_id: 任务ID
        interval: 轮询间隔（默认 10 秒）
        max_attempts: 最大轮询次数（默认 30）
        result_endpoint: 如需调用特定接口获取详细结果（如 querySimplifiedDeclareTaskInfo）

    Returns:
        {"ok": True/False, "status": "completed/failed/processing", "data": ...}
    """
    interval = interval or POLL_INTERVAL
    max_attempts = max_attempts or POLL_MAX

    for i in range(1, max_attempts + 1):
        result = api_call("query_task_info", payload={
            "aggOrgId": agg_org_id,
            "taskId": task_id,
        })

        if not result["ok"]:
            log.warning(f"轮询第 {i}/{max_attempts} 次失败: {result.get('error')}")
            if i < max_attempts:
                time.sleep(interval)
                continue
            return {
                "ok": False,
                "status": "error",
                "error": result.get("error"),
                "poll_attempts": i,
            }

        data = result["data"]
        # business_status 可能在 data 顶层或嵌套的 data 里
        biz_data = data.get("data", data)
        status = biz_data.get(STATUS_FIELD, biz_data.get("businessStatus"))

        if status == STATUS_COMPLETED:
            # 任务完成，如有特定结果接口则再调一次
            if result_endpoint:
                detail = api_call(result_endpoint, payload={
                    "aggOrgId": agg_org_id,
                    "taskId": task_id,
                })
                if detail["ok"]:
                    return {
                        "ok": True,
                        "status": "completed",
                        "data": detail["data"],
                        "poll_attempts": i,
                    }
                else:
                    return {
                        "ok": True,
                        "status": "completed",
                        "data": data,
                        "detail_error": detail.get("error"),
                        "poll_attempts": i,
                    }

            return {
                "ok": True,
                "status": "completed",
                "data": data,
                "poll_attempts": i,
            }

        elif status == STATUS_FAILED:
            error_msg = biz_data.get("message", biz_data.get("msg", "任务失败"))
            return {
                "ok": False,
                "status": "failed",
                "data": data,
                "error": error_msg,
                "poll_attempts": i,
            }

        # 进行中，继续轮询
        log.info(f"轮询第 {i}/{max_attempts} 次，状态: processing (business_status={status})")
        if i < max_attempts:
            time.sleep(interval)

    return {
        "ok": False,
        "status": "processing",
        "error": f"轮询 {max_attempts} 次后仍在处理中",
        "poll_attempts": max_attempts,
    }


# ── 状态持久化 ────────────────────────────────────────
def _state_path(task_id: str) -> Path:
    return STATE_DIR / f"{task_id}.json"

def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()

def create_task(company_id: str, company_name: str, period: str,
                agg_org_id: str = "", company_type: str = "small_scale") -> dict:
    task_id = f"decl_{period.replace('-', '')}_{company_id}"
    state = {
        "task_id": task_id,
        "company_id": company_id,
        "company_name": company_name,
        "agg_org_id": agg_org_id,
        "company_type": company_type,
        "period": period,
        "state": "INIT",
        "state_history": [],
        "data": {
            "tax_list": None,
            "declaration_forms": None,
            "init_data": None,
            "parsed_excel": None,
            "user_confirmations": None,
            "calculated_taxes": None,
            "policy_matches": None,
            "validation_result": None,
            "submit_result": None,
            "receipt_url": None,
            "receipt_data": None,
        },
        "interactions": {},
        "retry_count": 0,
        "max_retries": 3,
        "error": None,
        "created_at": now_iso(),
        "updated_at": now_iso(),
    }
    save_state(task_id, state)
    return state

def load_state(task_id: str) -> dict | None:
    p = _state_path(task_id)
    if not p.exists():
        return None
    with open(p) as f:
        return json.load(f)

def save_state(task_id: str, state: dict):
    state["updated_at"] = now_iso()
    with open(_state_path(task_id), "w") as f:
        json.dump(state, f, ensure_ascii=False, indent=2)

def transition(state: dict, new_state: str, result: str = "ok") -> dict:
    state["state_history"].append({
        "state": state["state"],
        "at": now_iso(),
        "result": result,
    })
    state["state"] = new_state
    state["retry_count"] = 0
    state["error"] = None
    save_state(state["task_id"], state)
    log.info(f"[{state['task_id']}] {state['state_history'][-1]['state']} → {new_state} ({result})")
    return state

def fail(state: dict, error: str) -> dict:
    state["error"] = error
    state["retry_count"] += 1
    save_state(state["task_id"], state)
    log.error(f"[{state['task_id']}] FAILED at {state['state']}: {error} (retry {state['retry_count']})")
    return state

def list_tasks(status_filter: str = None) -> list:
    tasks = []
    for f in STATE_DIR.glob("*.json"):
        with open(f) as fh:
            task = json.load(fh)
            if status_filter is None or task["state"] == status_filter:
                tasks.append(task)
    return tasks

# ── 输出 / 解析 ──────────────────────────────────────
def output(result: dict):
    print(json.dumps(result, ensure_ascii=False, indent=2))

def parse_args() -> dict:
    if len(sys.argv) > 1:
        return json.loads(sys.argv[1])
    if not sys.stdin.isatty():
        import select
        if select.select([sys.stdin], [], [], 0.1)[0]:
            raw = sys.stdin.read().strip()
            if raw:
                return json.loads(raw)
    return {}
